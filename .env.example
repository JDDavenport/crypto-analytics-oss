# crypto-analytics-oss — optional configuration. NOTHING here is required to run.
# Copy to `.env` and fill only the values you want. No exchange keys are ever used.

# --- Optional data-source keys (layers degrade to neutral without them) ---
# FRED (macro layer: dollar index + Fed funds). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# CoinGlass (derivatives layer: perp funding rate). Free tier: https://www.coinglass.com/
COINGLASS_API_KEY=

# --- Optional risk-cap / scorer overrides (sensible defaults built in) ---
# CA_MAX_LEVERAGE=3.0        # guardrail refuses leverage above this
# CA_MMR=0.005               # maintenance margin rate used in the liq formula
# CA_LIQ_ATR_BUFFER=1.0      # liquidation must sit > this many ATRs from entry
# CA_W_TA=0.28
# CA_W_DERIVATIVES=0.27
# CA_W_ONCHAIN=0.20
# CA_W_MACRO=0.15
# CA_W_SENTIMENT=0.10

# --- Web server ---
# PORT=8787
